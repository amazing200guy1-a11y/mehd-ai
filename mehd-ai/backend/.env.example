# Copy to .env and fill values
# NEVER commit .env itself

DEMO_MODE=true

# AI Agents (free tiers available)
GROQ_API_KEY=get_free_at_groq.com
GEMINI_API_KEY=get_free_at_aistudio.google.com
MISTRAL_API_KEY=get_free_at_console.mistral.ai

# Market Data (Triple-redundancy: OANDA → Polygon → TwelveData → Mock)
TWELVEDATA_API_KEY=get_free_at_twelvedata.com
POLYGON_API_KEY=get_free_at_polygon.io

# Broker
OANDA_API_KEY=get_free_demo_at_oanda.com
OANDA_ACCOUNT_ID=your_account_id

# Payments — THE BATTERY SLOT
# Create products/prices in Stripe Dashboard, paste IDs here
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_GUARDIAN=
STRIPE_PRICE_OPERATIVE=
STRIPE_PRICE_SOVEREIGN=

# Server-controlled redirect URLs (SECURITY: never accept from client)
CHECKOUT_SUCCESS_URL=https://mehdai.com/success.html
CHECKOUT_CANCEL_URL=https://mehdai.com/#pricing

# Security (REQUIRED for production)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CAPSULE_SIGNING_SECRET=
RISK_INTERNAL_TOKEN=

# Encryption — Broker API keys are AES-encrypted at rest using this key.
# REQUIRED for production. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_MASTER_KEY=

# Monitoring — know when things break before users tell you
# Create a free account at sentry.io → Settings → DSN
SENTRY_DSN=
