# ──────────────────────────────────────────────
#  Mehd AI — Environment Variables
# ──────────────────────────────────────────────
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to git — only .env.example.
# ──────────────────────────────────────────────

# Firebase Configuration
# Path to your Firebase service account JSON key file.
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json

# Your Firebase project ID (visible in Firebase Console → Project Settings)
FIREBASE_PROJECT_ID=your-firebase-project-id

# ──────────────────────────────────────────────
#  Phase 2 — AI Model API Keys (not needed yet)
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIzaSy...
XAI_API_KEY=xai-...
PERPLEXITY_API_KEY=pplx-...
DEEPSEEK_API_KEY=sk-...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...
