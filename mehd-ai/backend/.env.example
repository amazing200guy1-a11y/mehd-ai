# Copy to .env and fill values
# NEVER commit .env itself

DEMO_MODE=true

# AI Agents (free tiers available)
GROQ_API_KEY=get_free_at_groq.com
GEMINI_API_KEY=get_free_at_aistudio.google.com
MISTRAL_API_KEY=get_free_at_console.mistral.ai

# Market Data (Triple-redundancy: OANDA → Polygon → TwelveData → Mock)
TWELVEDATA_API_KEY=get_free_at_twelvedata.com
POLYGON_API_KEY=get_free_at_polygon.io

# Broker
OANDA_API_KEY=get_free_demo_at_oanda.com
OANDA_ACCOUNT_ID=your_account_id

# ──────────────────────────────────────────────────────────────────────────────
#  PAYMENTS — DUAL GATEWAY (Paddle + Paystack)
# ──────────────────────────────────────────────────────────────────────────────
#
#  WHY TWO GATEWAYS?
#  - Paddle   → Global (US, Europe, Asia, LatAm): Cards, PayPal, Apple/Google Pay.
#               Acts as Merchant of Record so Paddle pays ALL global VAT/taxes for us.
#  - Paystack → Africa (Nigeria, South Africa, Ghana, Kenya):
#               Local bank transfer, USSD, Mobile Money (M-Pesa, MTN), Verve cards.
#
#  HOW TO CONFIGURE:
#  1. Log in to https://paddle.com → Products → Create 3 products (Core, Precision, Institutional)
#     → Copy the Price IDs (e.g. pri_xxxxxxxxxx) into PADDLE_PRICE_* below.
#  2. In Paddle Developer Dashboard → Notifications → Create Webhook
#     → Endpoint URL: https://your-backend.railway.app/payments/paddle-webhook
#     → Events: subscription.created, subscription.updated, subscription.canceled
#     → Copy the signing secret into PADDLE_WEBHOOK_SECRET.
#
#  3. Log in to https://dashboard.paystack.com → Subscriptions → Plans
#     → Create 3 plans (Core, Precision, Institutional) in NGN (or USD with conversion)
#     → Copy Plan Codes (e.g. PLN_xxxxxxxxxx) into PAYSTACK_PLAN_* below.
#  4. In Paystack Settings → API Keys → Copy your Secret Key into PAYSTACK_SECRET_KEY.
#  5. In Paystack Settings → Webhooks → Set URL: https://your-backend.railway.app/payments/paystack-webhook

# ── PADDLE ──
# Get your webhook signing secret from: Paddle Dashboard → Developer → Notifications
PADDLE_WEBHOOK_SECRET=

# Price IDs from Paddle Dashboard → Catalog → Prices
PADDLE_PRICE_CORE=
PADDLE_PRICE_PRECISION=
PADDLE_PRICE_INSTITUTIONAL=

# ── PAYSTACK ──
# Get from: Paystack Dashboard → Settings → API Keys & Webhooks
PAYSTACK_SECRET_KEY=

# Plan Codes from Paystack Dashboard → Subscriptions → Plans
PAYSTACK_PLAN_CORE=
PAYSTACK_PLAN_PRECISION=
PAYSTACK_PLAN_INSTITUTIONAL=

# ── SHARED REDIRECT URLS ──
# These are server-controlled — NEVER accept redirect URLs from the client.
CHECKOUT_SUCCESS_URL=https://mehdai.com/success.html
PRICING_URL=https://mehdai.com/#pricing

# ──────────────────────────────────────────────────────────────────────────────

# Security (REQUIRED for production)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CAPSULE_SIGNING_SECRET=
RISK_INTERNAL_TOKEN=

# Encryption — Broker API keys are AES-encrypted at rest using this key.
# REQUIRED for production. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_MASTER_KEY=

# Monitoring — know when things break before users tell you
# Create a free account at sentry.io → Settings → DSN
SENTRY_DSN=
